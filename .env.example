# DeepSeek is used only for Article Topic Ideas.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ARTICLE_IDEA_MODEL=deepseek-v4-pro
DEEPSEEK_ARTICLE_IDEA_THINKING=1
DEEPSEEK_ARTICLE_IDEA_REASONING_EFFORT=high
DEEPSEEK_ARTICLE_IDEA_MAX_TOKENS=12000

# OpenAI GPT-5.6 routing for Article Writer, Revision and the optional model humaniser.
# Terra handles standard/lower-cost drafting and humanisation. Sol handles doctoral, research-heavy, review, long and revision work.
OPENAI_API_KEY=
OPENAI_ARTICLE_TERRA_MODEL=gpt-5.6-terra
OPENAI_ARTICLE_SOL_MODEL=gpt-5.6-sol
OPENAI_ARTICLE_BACHELOR_MODEL=gpt-5.6-terra
OPENAI_ARTICLE_MASTERS_MODEL=gpt-5.6-terra
OPENAI_ARTICLE_RESEARCH_MODEL=gpt-5.6-sol
OPENAI_ARTICLE_DOCTORAL_MODEL=gpt-5.6-sol
OPENAI_ARTICLE_REVISION_MODEL=gpt-5.6-sol
OPENAI_ARTICLE_HUMANIZER_MODEL=gpt-5.6-terra
OPENAI_ARTICLE_FALLBACK_MODEL=gpt-5.6-terra

ARTICLEREADY_IDEA_USE_AI=1
ARTICLEREADY_IDEA_SOURCE_LIMIT=16
ARTICLEREADY_ARTICLE_USE_AI=1
ARTICLEREADY_REVISION_USE_AI=1
ARTICLEREADY_ARTICLE_SOURCE_LIMIT=60
ARTICLEREADY_ARTICLE_MAX_SOURCE_CONTEXT=80
ARTICLEREADY_BATCH_DRAFT_WORD_THRESHOLD=6500
ARTICLEREADY_ARTICLE_MAX_OUTPUT_TOKENS=24000
ARTICLEREADY_ARTICLE_HARD_OUTPUT_CAP=60000
ARTICLEREADY_ARTICLE_MATERIAL_CHARS=120000
ARTICLEREADY_ARTICLE_CONTINUATION_CHARS=140000
ARTICLEREADY_ARTICLE_DATA_CHARS=120000
ARTICLEREADY_AUTHOR_GUIDELINE_CHARS=30000
OPENALEX_MAILTO=
CROSSREF_MAILTO=
ARTICLEREADY_MAX_UPLOAD_BYTES=15728640
ARTICLEREADY_MAX_EXTRACTED_CHARS=190000

# ThesisReady-derived scholarly humanisation layer
ARTICLEREADY_STRONG_HUMANISATION=1
ARTICLEREADY_HUMANISATION_STRENGTH=strong
ARTICLEREADY_HUMANIZER_MODE=balanced
ARTICLEREADY_HUMANIZER_MODEL_PASS=1
ARTICLEREADY_HUMANIZER_MODEL_THRESHOLD=97
ARTICLEREADY_HUMANIZER_BATCH_WORDS=1800
ARTICLEREADY_HUMANIZER_MAX_BATCHES_BALANCED=6
ARTICLEREADY_HUMANIZER_MAX_BATCHES_DEEP=16
ARTICLEREADY_HUMANIZER_PERPLEXITY_LEVEL=high
ARTICLEREADY_HUMANIZER_BURSTINESS_LEVEL=high
ARTICLEREADY_HUMANIZER_MAX_WORD_CHANGE_RATIO=0.06
# Optional fixed salt for deterministic post-processing across deployments
ARTICLEREADY_HUMANISATION_SEED_SALT=articleready-v2

# Payment system
# Keep this enabled in production. Set to 0 only for local testing.
ARTICLEREADY_PAYMENT_REQUIRED=1
APP_BASE_URL=https://articlereadyai.com
ARTICLEREADY_PAYMENT_SUCCESS_PATH=/pricing
ARTICLEREADY_PAYMENT_CANCEL_PATH=/pricing
ARTICLEREADY_SQLITE_DB_PATH=/var/data/articleready_payments.db

# Paystack, used for African billing countries
PAYSTACK_SECRET_KEY=
ARTICLEREADY_PAYSTACK_USD_TO_GHS_RATE=15.00
# Optional fixed GHS prices per plan. If blank, USD prices are converted using the rate above.
ARTICLEREADY_PAYSTACK_ARTICLE_IDEAS_GHS=
ARTICLEREADY_PAYSTACK_STAGE1_GHS=
ARTICLEREADY_PAYSTACK_STANDARD_ARTICLE_GHS=
ARTICLEREADY_PAYSTACK_LONG_ARTICLE_GHS=
ARTICLEREADY_PAYSTACK_REVIEW_ARTICLE_GHS=
ARTICLEREADY_PAYSTACK_ARTICLE_REVISION_GHS=
ARTICLEREADY_PAYSTACK_REVIEWER_REVISION_GHS=
ARTICLEREADY_PAYSTACK_EXTRA_REVISION_GHS=

# Stripe, used for non-African billing countries
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Restricted developer access. Keep disabled unless needed.
# Use a strong unique code. For stronger secrecy, set only the SHA-256 hash of the code.
ARTICLEREADY_DEVELOPER_ACCESS_ENABLED=0
ARTICLEREADY_DEVELOPER_ACCESS_EMAIL=
ARTICLEREADY_DEVELOPER_ACCESS_CODE=
ARTICLEREADY_DEVELOPER_ACCESS_CODE_SHA256=
ARTICLEREADY_DEVELOPER_ACCESS_SECRET=
ARTICLEREADY_DEVELOPER_SESSION_HOURS=12

# Synthesis articles of this length or more use batch drafting in Auto mode.
ARTICLEREADY_SYNTHESIS_BATCH_DRAFT_WORD_THRESHOLD=9500
