# DeepSeek is used only for Article Topic Ideas.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ARTICLE_IDEA_MODEL=deepseek-v4-pro
DEEPSEEK_ARTICLE_IDEA_THINKING=1
DEEPSEEK_ARTICLE_IDEA_REASONING_EFFORT=high
DEEPSEEK_ARTICLE_IDEA_MAX_TOKENS=12000

# OpenAI remains the provider for the Article Writer.
OPENAI_API_KEY=
OPENAI_ARTICLE_BACHELOR_MODEL=gpt-5.4
OPENAI_ARTICLE_MASTERS_MODEL=gpt-5.4
OPENAI_ARTICLE_RESEARCH_MODEL=gpt-5.5
OPENAI_ARTICLE_DOCTORAL_MODEL=gpt-5.5

JOURNALREADY_IDEA_USE_AI=1
JOURNALREADY_IDEA_SOURCE_LIMIT=16
JOURNALREADY_ARTICLE_USE_AI=1
JOURNALREADY_ARTICLE_SOURCE_LIMIT=60
JOURNALREADY_ARTICLE_MAX_SOURCE_CONTEXT=80
OPENALEX_MAILTO=
CROSSREF_MAILTO=
JOURNALREADY_MAX_UPLOAD_BYTES=15728640
JOURNALREADY_MAX_EXTRACTED_CHARS=90000
