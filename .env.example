# DeepSeek is used only for Article Topic Ideas.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ARTICLE_IDEA_MODEL=deepseek-v4-pro
DEEPSEEK_ARTICLE_IDEA_THINKING=1
DEEPSEEK_ARTICLE_IDEA_REASONING_EFFORT=high
DEEPSEEK_ARTICLE_IDEA_MAX_TOKENS=12000

# OpenAI remains the provider for the Article Writer and Article Revision modules.
OPENAI_API_KEY=
OPENAI_ARTICLE_BACHELOR_MODEL=gpt-5.4
OPENAI_ARTICLE_MASTERS_MODEL=gpt-5.4
OPENAI_ARTICLE_RESEARCH_MODEL=gpt-5.5
OPENAI_ARTICLE_DOCTORAL_MODEL=gpt-5.5
OPENAI_ARTICLE_REVISION_MODEL=gpt-5.5

ARTICLEREADY_IDEA_USE_AI=1
ARTICLEREADY_IDEA_SOURCE_LIMIT=16
ARTICLEREADY_ARTICLE_USE_AI=1
ARTICLEREADY_REVISION_USE_AI=1
ARTICLEREADY_ARTICLE_SOURCE_LIMIT=60
ARTICLEREADY_ARTICLE_MAX_SOURCE_CONTEXT=80
OPENALEX_MAILTO=
CROSSREF_MAILTO=
ARTICLEREADY_MAX_UPLOAD_BYTES=15728640
ARTICLEREADY_MAX_EXTRACTED_CHARS=90000

# Strong human-supervised academic writing layer
ARTICLEREADY_STRONG_HUMANISATION=1
ARTICLEREADY_HUMANISATION_STRENGTH=strong
# Optional fixed salt for deterministic post-processing across deployments
ARTICLEREADY_HUMANISATION_SEED_SALT=articleready-v1
