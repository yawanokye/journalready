# =========================================================
# ARTICLEREADY AI 2.1 PRODUCTION CONFIGURATION
# Copy the required values into Render. Never commit real secrets.
# =========================================================

# Public application URL
APP_BASE_URL=https://articlereadyai.com

# OpenAI
OPENAI_API_KEY=
# Use model IDs available to your OpenAI project.
OPENAI_ARTICLE_STANDARD_MODEL=gpt-5-mini
OPENAI_ARTICLE_ADVANCED_MODEL=gpt-5.1
OPENAI_ARTICLE_REVISION_MODEL=gpt-5.1
OPENAI_ARTICLE_FALLBACK_MODELS=gpt-5.1,gpt-5,gpt-5-mini
OPENAI_ARTICLEREADY_TIMEOUT_SECONDS=180
OPENAI_ARTICLEREADY_SDK_RETRIES=2
OPENAI_ARTICLEREADY_ATTEMPTS_PER_MODEL=2
OPENAI_ARTICLEREADY_RETRY_BASE_SECONDS=1.5
OPENAI_ARTICLEREADY_CHAT_FALLBACK=1
ARTICLEREADY_REVISION_USE_AI=1
# Keep disabled in production. A failed paid revision will then roll back its
# entitlement instead of returning the original manuscript as completed work.
ARTICLEREADY_ALLOW_REVISION_FALLBACK=0
ARTICLEREADY_REVISION_MAX_OUTPUT_TOKENS=32000
ARTICLEREADY_REVISION_REPORT_MAX_OUTPUT_TOKENS=7000

# Scholarly metadata providers
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_MAILTO=aadam@ucc.edu.gh
CROSSREF_MAILTO=aadam@ucc.edu.gh
ARTICLEREADY_METADATA_MAX_ATTEMPTS=3
ARTICLEREADY_METADATA_RETRY_BASE_SECONDS=1.0
ARTICLEREADY_METADATA_429_COOLDOWN_SECONDS=60
ARTICLEREADY_METADATA_USER_AGENT=ArticleReadyAI/2.1 (contact: aadam@ucc.edu.gh)

# Persistent data
ARTICLEREADY_SQLITE_DB_PATH=/var/data/articleready_payments.db
ARTICLEREADY_REVIEW_DB_PATH=/var/data/articleready_review_workspace.db

# Payments
ARTICLEREADY_PAYMENT_REQUIRED=1
PAYSTACK_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Developer access
ARTICLEREADY_DEVELOPER_ACCESS_ENABLED=0
ARTICLEREADY_DEVELOPER_ACCESS_EMAIL=aadam@ucc.edu.gh
ARTICLEREADY_DEVELOPER_ACCESS_CODE_SHA256=
# Generate a separate long random signing secret. Do not reuse the login code.
ARTICLEREADY_DEVELOPER_ACCESS_SECRET=
ARTICLEREADY_DEVELOPER_SESSION_HOURS=12

# Application security
ARTICLEREADY_ALLOWED_HOSTS=articlereadyai.com,www.articlereadyai.com,*.onrender.com,localhost,127.0.0.1,testserver
ARTICLEREADY_ALLOWED_ORIGINS=https://articlereadyai.com,https://www.articlereadyai.com
ARTICLEREADY_TRUST_PROXY_HEADERS=1
ARTICLEREADY_RATE_LIMIT_ENABLED=1
ARTICLEREADY_HSTS_ENABLED=1
ARTICLEREADY_ENABLE_API_DOCS=0
ARTICLEREADY_SECURITY_CONTACT=mailto:aadam@ucc.edu.gh
ARTICLEREADY_SECURITY_CANONICAL=https://articlereadyai.com/.well-known/security.txt
ARTICLEREADY_MAX_REQUEST_BYTES=2097152
ARTICLEREADY_MAX_JSON_REQUEST_BYTES=6291456
ARTICLEREADY_MAX_UPLOAD_REQUEST_BYTES=17825792
ARTICLEREADY_MAX_REVIEW_UPLOAD_BYTES=54525952
ARTICLEREADY_MAX_OFFICE_UNCOMPRESSED_BYTES=157286400
ARTICLEREADY_MAX_OFFICE_ARCHIVE_FILES=5000
ARTICLEREADY_MAX_PDF_PAGES=1000
